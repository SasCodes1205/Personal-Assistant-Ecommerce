# ----- Database -----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ceo_assistant"

# ----- Anthropic -----
ANTHROPIC_API_KEY=""
# Model identifiers — VERIFY current model strings before deploy.
MODEL_TRIAGE="claude-haiku-4-5-20251001"
MODEL_DRAFT="claude-sonnet-4-6"
MODEL_BRIEFING="claude-opus-4-8"
MODEL_EXTRACTION="claude-sonnet-4-6"
MODEL_COMPLIANCE="claude-opus-4-8"     # high-tier model for the compliance gatekeeper

# ----- AssemblyAI (transcription FALLBACK — Zoom / in-person / uploaded) -----
ASSEMBLYAI_API_KEY=""
ASSEMBLYAI_WEBHOOK_AUTH_HEADER="X-Webhook-Secret"
ASSEMBLYAI_WEBHOOK_SECRET=""

# ----- Microsoft 365 / Entra app registration (replaces Google/Gmail) -----
AZURE_TENANT_ID=""                     # Directory (tenant) ID
AZURE_CLIENT_ID=""                     # Application (client) ID
AZURE_CLIENT_SECRET=""                 # client secret VALUE (shown once)
MS_MAILBOX=""                          # CEO email / UPN, e.g. nalin@yourtenant.com
GRAPH_SUBSCRIPTION_CLIENT_STATE=""     # random string; validates incoming notifications

# ----- Microsoft Teams (replaces Slack) -----
TEAMS_WEBHOOK_URL=""                   # Power Automate "Workflows" incoming webhook URL

# ----- Server / webhooks -----
PUBLIC_API_URL="http://localhost:4000" # public base URL Graph posts notifications to (use ngrok locally)
INTERNAL_API_SECRET=""                 # bearer secret for internal trigger endpoints (briefings, renew)
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGIN=http://localhost:3000

# ----- Inngest (optional) -----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ----- Supabase (only needed for AssemblyAI upload path) -----
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# ----- CEO context -----
CEO_NAME="Nalin Siriwardhana"
CEO_TIMEZONE="America/New_York"
TEAM_TIMEZONE="Asia/Colombo"
