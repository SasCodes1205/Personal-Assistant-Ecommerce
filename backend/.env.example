# ----- Database -----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ceo_assistant"

# ----- Anthropic -----
ANTHROPIC_API_KEY=""
# Model identifiers (per system prompt: Opus 4.7 is current top, Sonnet 4.6, Haiku 4.5)
MODEL_TRIAGE="claude-haiku-4-5-20251001"
MODEL_DRAFT="claude-sonnet-4-6"
MODEL_BRIEFING="claude-opus-4-7"
MODEL_EXTRACTION="claude-sonnet-4-6"

# ----- AssemblyAI (transcription) -----
ASSEMBLYAI_API_KEY=""
ASSEMBLYAI_WEBHOOK_AUTH_HEADER="X-Webhook-Secret"
ASSEMBLYAI_WEBHOOK_SECRET=""

# ----- Google / Gmail -----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""      # CEO's refresh token, obtained one-time via OAuth flow
GMAIL_USER_EMAIL=""          # CEO's email address
GMAIL_PUSH_TOPIC=""          # projects/<id>/topics/gmail-push

# ----- Slack -----
SLACK_BOT_TOKEN=""           # xoxb-...
SLACK_SIGNING_SECRET=""
SLACK_CEO_USER_ID=""         # for DMs (e.g. U0123ABC)
SLACK_BRIEFINGS_CHANNEL=""   # e.g. #ceo-briefings

# ----- Inngest -----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ----- Supabase (optional — for storage of meeting audio) -----
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# ----- Server -----
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGIN=http://localhost:3000

# ----- CEO context (used to scope prompts) -----
CEO_NAME="Nalin Siriwardhana"
CEO_TIMEZONE="America/New_York"
TEAM_TIMEZONE="Asia/Colombo"
